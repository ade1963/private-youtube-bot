TELEGRAM_BOT_TOKEN=123456:replace-me

# Comma/space separated Telegram chat IDs.
ALLOWED_CHAT_IDS=111111111,222222222
ADMIN_CHAT_IDS=111111111

# Storage and quota limits. Plain bytes, MB, MiB, GB, GiB are accepted.
MAX_STORAGE_BYTES=1GB
WEEKLY_USER_LIMIT_BYTES=1GB

# Public Telegram Bot API upload limit is currently 50MB.
# If you run a local Bot API server, you can raise this.
TELEGRAM_MAX_UPLOAD_BYTES=50MB

# Global defaults used until a member changes their own settings.
DEFAULT_MEDIA=audio
DEFAULT_VIDEO_RESOLUTION=720
DEFAULT_AUDIO_QUALITY=192
DEFAULT_AUDIO_FORMAT=mp3

# Local paths on the VPS.
BOT_DATA_DIR=data
DOWNLOAD_DIR=downloads

# Number of full diagnostic entries kept in data/state.json.
ERROR_HISTORY_LIMIT=100
